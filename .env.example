# ---------- Vidy environment manifest ----------
# Copy to .env.local for dev, set in Coolify for prod.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
PORT=3000

# Database (PostgreSQL - self-hosted on Coolify or external)
DATABASE_URL=postgresql://vidy:vidy@localhost:5432/vidy?schema=public

# Auth (better-auth)
BETTER_AUTH_SECRET=                 # openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudflare R2 (object storage for inputs + outputs)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=vidy
R2_PUBLIC_URL=https://cdn.example.com

# fal.ai
FAL_KEY=                            # also accepted as FAL_API_KEY
FAL_WEBHOOK_SECRET=                 # HMAC secret to verify queue callbacks
FAL_WEBHOOK_PUBLIC_URL=             # public URL fal can reach (e.g. https://vidy.app)

# OpenAI (agent planner)
OPENAI_API_KEY=
OPENAI_PLANNER_MODEL=gpt-5
OPENAI_REFLECTOR_MODEL=gpt-5-mini
OPENAI_VISION_MODEL=gpt-5

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_COINS_5K=
STRIPE_PRICE_COINS_25K=
STRIPE_PRICE_COINS_100K=
STRIPE_PRICE_UNLIMITED_MONTHLY=

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Resend (transactional email)
RESEND_API_KEY=

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_GA_ID=

# Misc
CRON_SECRET=
